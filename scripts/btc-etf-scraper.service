[Unit]
Description=BTC ETF Scraper Service
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=jjphy
WorkingDirectory=/opt/jjphy/BTC-ETFs-Scraper
ExecStart=/bin/bash /opt/jjphy/BTC-ETFs-Scraper/scripts/vps_run.sh
StandardOutput=append:/opt/jjphy/BTC-ETFs-Scraper/scraper.log
StandardError=append:/opt/jjphy/BTC-ETFs-Scraper/scraper.log

[Install]
WantedBy=multi-user.target
